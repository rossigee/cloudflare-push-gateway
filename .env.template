# Cloudflare API credentials for deployment
# Copy to .env and fill in values
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Optional: local dev secrets (also used by .dev.vars)
# PUSHGATEWAY_AUTH_USER=admin
# PUSHGATEWAY_AUTH_PASS=changeme

# JWT/OIDC authentication (users):
# JWT_ISSUER=https://accounts.google.com
# JWT_AUDIENCE=your-client-id.apps.googleusercontent.com
# JWKS_URI=

# API tokens for consumer apps (comma-separated):
# API_TOKENS=tok1,tok2
